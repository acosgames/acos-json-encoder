{
    "name": "acos-json-encoder",
    "version": "2.0.5",
    "description": "JSON serializer and deserializer used by ACOS.games",
    "main": "dist/cjs/index.js",
    "module": "dist/esm/index.js",
    "types": "dist/cjs/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js",
            "types": "./dist/cjs/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json",
        "test": "npm run build && node --inspect=9932 dist/cjs/test.js",
        "test-full": "npm run build && node --inspect=9932 dist/cjs/test-full.js"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/acosgames/acos-json-encoder.git"
    },
    "author": "acosg",
    "license": "MIT",
    "files": [
        "dist/cjs",
        "dist/esm"
    ],
    "devDependencies": {
        "@types/node": "^22.19.17",
        "typescript": "^5.8.3"
    }
}
