{
    "name": "acos-json-encoder",
    "version": "1.0.19",
    "description": "JSON serializer and deserializer used by ACOS.games",
    "main": "dist/cjs/encoder.js",
    "module": "dist/esm/encoder.js",
    "types": "dist/cjs/encoder.d.ts",
    "exports": {
        ".": {
            "import": "./dist/esm/encoder.js",
            "require": "./dist/cjs/encoder.js",
            "types": "./dist/cjs/encoder.d.ts"
        },
        "./protocol": {
            "import": "./dist/esm/protocol.js",
            "require": "./dist/cjs/protocol.js",
            "types": "./dist/cjs/protocol.d.ts"
        }
    },
    "scripts": {
        "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json",
        "test": "npm run build && node dist/cjs/tests.js"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/acosgames/acos-json-encoder.git"
    },
    "author": "acosg",
    "license": "MIT",
    "files": [
        "dist/cjs",
        "dist/esm"
    ],
    "devDependencies": {
        "@types/node": "^22.19.17",
        "typescript": "^5.8.3"
    }
}
